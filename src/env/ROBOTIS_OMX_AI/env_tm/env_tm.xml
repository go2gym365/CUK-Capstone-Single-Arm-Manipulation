<mujoco model="omx_ai_pick_place">
  <compiler angle="radian" meshdir="assets/" autolimits="true"/>
  <option timestep="0.005" gravity="0 0 -9.81" integrator="RK4" cone="elliptic" impratio="10"/>
  <size njmax="3000" nconmax="800"/>

  <statistic center="0.16 0 0.24" extent="0.75"/>

  <visual>
    <headlight ambient="0.45 0.45 0.45" diffuse="0.75 0.75 0.75" specular="0.15 0.15 0.15"/>
    <rgba haze="0.15 0.25 0.35 1"/>
    <global azimuth="125" elevation="-22"/>
  </visual>

  <asset>
    <material name="black" rgba="0.1 0.1 0.1 1"/>
    <material name="mat_table" rgba="0.45 0.32 0.22 1"/>
    <material name="mat_cube" rgba="0.72 0.30 0.82 0.95"/>
    <material name="mat_bottle" rgba="0.72 0.86 0.96 0.45"/>
    <material name="mat_cap" rgba="0.12 0.38 0.90 1"/>

    <texture name="tex_floor_checker"
             type="2d"
             builtin="checker"
             rgb1="0.82 0.82 0.82"
             rgb2="0.62 0.62 0.62"
             width="512"
             height="512"/>
    <material name="mat_floor_checker"
              texture="tex_floor_checker"
              texrepeat="8 8"
              texuniform="true"
              reflectance="0.05"/>

    <mesh name="follower_01_base" file="follower_01_base.stl" scale="0.001 0.001 0.001"/>
    <mesh name="follower_02_base_tilt_Revised" file="follower_02_base_tilt_Revised.stl" scale="0.001 0.001 0.001"/>
    <mesh name="follower_03_middle_verticle" file="follower_03_middle_verticle.stl" scale="0.001 0.001 0.001"/>
    <mesh name="follower_04_middle_horizontal" file="follower_04_middle_horizontal.stl" scale="0.001 0.001 0.001"/>
    <mesh name="follower_05_tip" file="follower_05_tip.stl" scale="0.001 0.001 0.001"/>
    <mesh name="follower_06_pan_Revised" file="follower_06_pan_Revised.stl" scale="0.001 0.001 0.001"/>
    <mesh name="follower_07_gripper_motorized" file="follower_07_gripper_motorized.stl" scale="0.001 0.001 0.001"/>
    <mesh name="follower_08_gripper_gear" file="follower_08_gripper_gear.stl" scale="0.001 0.001 0.001"/>
  </asset>

  <default>
    <default class="omx">
      <joint frictionloss="0.1" armature="0.1" damping="0.4"/>
      <position kp="50" dampratio="1" forcerange="-3.5 3.5"/>

      <default class="Joint1">
        <joint axis="0 0 1" range="-4.712389 6.283185"/>
      </default>
      <default class="Joint2">
        <joint axis="0 1 0" range="-2.094395 1.570796"/>
      </default>
      <default class="Joint3">
        <joint axis="0 1 0" range="-2.094395 1.570796"/>
      </default>
      <default class="Joint4">
        <joint axis="0 1 0" range="-1.745329 1.745329"/>
      </default>
      <default class="Joint5">
        <joint axis="1 0 0" range="-4.712389 4.712389"/>
      </default>
      <default class="Gripper">
        <joint axis="0 0 1" range="0 1.745329"/>
      </default>
      <default class="Gripper_mimic">
        <joint axis="0 0 1" range="-1.745329 0"/>
      </default>

      <default class="visual">
        <geom type="mesh" contype="0" conaffinity="0" density="0" group="2" material="black"/>
      </default>
      <default class="collision">
        <geom type="mesh" group="3" material="black" friction="0.9 0.05 0.01" condim="4"/>
      </default>
    </default>
  </default>

  <worldbody>
    <light pos="0 0 1.7" dir="0 0 -1"/>
    <camera name="front_cam" pos="0.10 0.75 0.55" xyaxes="-1 0 0 0 -0.45 0.89"/>
    <camera name="top_cam" pos="0.22 0.0 0.86" xyaxes="0 -1 0 1 0 0"/>
    <geom name="floor" type="plane" size="2 2 0.1" material="mat_floor_checker"/>

    <!-- Raised table and raised robot base. -->
    <body name="table" pos="0.24 0.0 0.10">
      <geom name="table_geom"
            type="box"
            size="0.34 0.40 0.02"
            material="mat_table"
            friction="1.0 0.05 0.01"/>
    </body>

    <!-- Objects on robot-right side (+y). -->
    <body name="object_cube" pos="0.205 0.090 0.145">
      <freejoint name="object_cube_free"/>
      <inertial pos="0 0 0" mass="0.030" diaginertia="0.00001 0.00001 0.00001"/>
      <geom name="object_cube_geom" type="box" size="0.020 0.020 0.020" material="mat_cube" friction="1.1 0.05 0.01"/>
      <site name="object_cube_site" pos="0 0 0" size="0.007" rgba="1 1 0 1"/>
    </body>

    <body name="object_bottle" pos="0.255 0.150 0.160">
      <freejoint name="object_bottle_free"/>
      <inertial pos="0 0 -0.01" mass="0.035" diaginertia="0.00001 0.00001 0.00001"/>
      <geom name="object_bottle_geom" type="cylinder" size="0.020 0.040" material="mat_bottle" friction="1.1 0.05 0.01"/>
      <geom name="object_bottle_neck" type="cylinder" size="0.013 0.014" pos="0 0 0.054" material="mat_bottle" friction="1.1 0.05 0.01"/>
      <geom name="object_bottle_cap" type="cylinder" size="0.014 0.007" pos="0 0 0.074" material="mat_cap" friction="1.1 0.05 0.01"/>
      <site name="object_bottle_site" pos="0 0 0" size="0.007" rgba="1 1 0 1"/>
    </body>

    <!-- Goals on robot-left side (-y). -->
    <body name="target_blue" pos="0.165 -0.205 0.124">
      <geom name="target_blue_geom" type="cylinder" size="0.032 0.004"
            rgba="0.2 0.45 1.0 0.9" contype="0" conaffinity="0"/>
      <site name="target_blue_site" pos="0 0 0.004" size="0.008"
            rgba="0.2 0.45 1 1"/>
    </body>

    <body name="target_purple" pos="0.285 -0.165 0.124">
      <geom name="target_purple_geom" type="cylinder" size="0.032 0.004"
            rgba="0.65 0.35 0.85 0.9" contype="0" conaffinity="0"/>
      <site name="target_purple_site" pos="0 0 0.004" size="0.008"
            rgba="0.65 0.35 0.85 1"/>
    </body>

    <body name="link0" pos="0 0 0.12" childclass="omx">
      <inertial pos="-1.441250800e-02 -3.149887900e-03 1.927659900e-02" quat="1 0 0 0" mass="2.238905100e-01" diaginertia="0.00035680461 0.00021941932 0.00045575899"/>
      <geom mesh="follower_01_base" class="visual"/>
      <geom mesh="follower_01_base" class="collision"/>
      <site name="base_site" pos="0 0 0" size="0.006" rgba="1 0 0 1"/>

      <body name="link1" pos="-0.01125 0 0.034">
        <inertial pos="-6.223620500e-06 6.049232000e-04 4.741880300e-02" quat="1 0 0 0" mass="6.598704100e-02" diaginertia="2.1731667e-05 2.1351513e-05 1.1657955e-05"/>
        <joint name="Joint1" class="Joint1"/>
        <geom mesh="follower_02_base_tilt_Revised" class="visual"/>
        <geom mesh="follower_02_base_tilt_Revised" class="collision"/>

        <body name="link2" pos="0 0 0.0635">
          <inertial pos="1.808991600e-02 2.977875800e-04 9.900545200e-02" quat="1 0 0 0" mass="8.722147100e-02" diaginertia="0.00010307915 0.00012086327 4.1993677e-05"/>
          <joint name="Joint2" class="Joint2"/>
          <geom mesh="follower_03_middle_verticle" class="visual"/>
          <geom mesh="follower_03_middle_verticle" class="collision"/>

          <body name="link3" pos="0.0415 0 0.11315">
            <inertial pos="8.739860200e-02 4.131006500e-04 -3.582921000e-03" quat="1 0 0 0" mass="8.375912900e-02" diaginertia="1.5203101e-05 0.00022606158 0.00023066887"/>
            <joint name="Joint3" class="Joint3"/>
            <geom mesh="follower_04_middle_horizontal" class="visual"/>
            <geom mesh="follower_04_middle_horizontal" class="collision"/>

            <body name="link4" pos="0.162 0 0">
              <inertial pos="2.323498000e-02 6.773537800e-05 5.976131200e-03" quat="1 0 0 0" mass="2.997506300e-02" diaginertia="5.099513e-06 7.0990471e-06 6.3119495e-06"/>
              <joint name="Joint4" class="Joint4"/>
              <geom mesh="follower_05_tip" class="visual"/>
              <geom mesh="follower_05_tip" class="collision"/>

              <body name="link5" pos="0.0287 0 0">
                <inertial pos="2.807240700e-02 2.413594100e-05 1.352891400e-02" quat="1 0 0 0" mass="4.381088700e-02" diaginertia="2.3694459e-05 2.3236924e-05 7.1806291e-06"/>
                <joint name="Joint5" class="Joint5"/>
                <geom mesh="follower_06_pan_Revised" class="visual"/>
                <geom mesh="follower_06_pan_Revised" class="collision"/>

                <site name="ee_site" pos="0.050 0.000 0.000" size="0.008" rgba="0 1 0 1"/>
                <site name="grasp_site" pos="0.062 -0.0015 0.000" size="0.010" rgba="1 0 0 1"/>

                <body name="link6" pos="0.0295 0.0075 0">
                  <inertial pos="1.616456500e-02 1.273103200e-03 2.729159800e-04" quat="1 0 0 0" mass="1.209067700e-02" diaginertia="2.7083287e-06 6.8733728e-06 4.6941881e-06"/>
                  <joint name="Gripper" class="Gripper"/>
                  <geom mesh="follower_07_gripper_motorized" class="visual"/>
                  <geom mesh="follower_07_gripper_motorized" class="collision"/>
                  <site name="left_finger_tip" pos="0.030 0.000 0.000" size="0.004" rgba="0 1 1 1"/>
                </body>

                <body name="link7" pos="0.0295 -0.0108 0">
                  <inertial pos="1.616456500e-02 1.273103200e-03 2.729159800e-04" quat="1 0 0 0" mass="1.209067700e-02" diaginertia="2.7083287e-06 6.8733728e-06 4.6941881e-06"/>
                  <joint name="Gripper_mimic" class="Gripper_mimic"/>
                  <geom mesh="follower_08_gripper_gear" class="visual"/>
                  <geom mesh="follower_08_gripper_gear" class="collision"/>
                  <site name="right_finger_tip" pos="0.030 0.000 0.000" size="0.004" rgba="0 1 1 1"/>
                </body>
              </body>
            </body>
          </body>
        </body>
      </body>
    </body>
  </worldbody>

  <actuator>
    <position class="Joint1" name="Joint1" joint="Joint1" inheritrange="1"/>
    <position class="Joint2" name="Joint2" joint="Joint2" inheritrange="1"/>
    <position class="Joint3" name="Joint3" joint="Joint3" inheritrange="1"/>
    <position class="Joint4" name="Joint4" joint="Joint4" inheritrange="1"/>
    <position class="Joint5" name="Joint5" joint="Joint5" inheritrange="1"/>
    <position class="Gripper" name="Gripper" joint="Gripper" inheritrange="1"/>
  </actuator>

  <contact>
    <exclude body1="link0" body2="link1"/>
    <exclude body1="link5" body2="link6"/>
    <exclude body1="link5" body2="link7"/>
    <exclude body1="link6" body2="link7"/>
  </contact>

  <equality>
    <joint joint1="Gripper_mimic" joint2="Gripper" polycoef="0 -1 0 0 0"/>
  </equality>

  <sensor>
    <jointpos name="joint1_pos" joint="Joint1"/>
    <jointpos name="joint2_pos" joint="Joint2"/>
    <jointpos name="joint3_pos" joint="Joint3"/>
    <jointpos name="joint4_pos" joint="Joint4"/>
    <jointpos name="joint5_pos" joint="Joint5"/>
    <jointpos name="gripper_pos" joint="Gripper"/>

    <jointvel name="joint1_vel" joint="Joint1"/>
    <jointvel name="joint2_vel" joint="Joint2"/>
    <jointvel name="joint3_vel" joint="Joint3"/>
    <jointvel name="joint4_vel" joint="Joint4"/>
    <jointvel name="joint5_vel" joint="Joint5"/>
    <jointvel name="gripper_vel" joint="Gripper"/>

    <framepos name="ee_pos" objtype="site" objname="ee_site"/>
    <framepos name="grasp_pos" objtype="site" objname="grasp_site"/>
    <framepos name="left_finger_pos" objtype="site" objname="left_finger_tip"/>
    <framepos name="right_finger_pos" objtype="site" objname="right_finger_tip"/>
    <framepos name="object_cube_pos" objtype="site" objname="object_cube_site"/>
    <framepos name="object_bottle_pos" objtype="site" objname="object_bottle_site"/>
    <framepos name="target_blue_pos" objtype="site" objname="target_blue_site"/>
    <framepos name="target_purple_pos" objtype="site" objname="target_purple_site"/>
  </sensor>

  <keyframe>
    <key name="home" qpos="0 0.05 -0.10 0.15 0 0 0.205 0.090 0.145 1 0 0 0 0.255 0.150 0.160 1 0 0 0" ctrl="0 0.05 -0.10 0.15 0 0.35"/>
    <key name="pregrasp_cube" qpos="0 0.45 -0.85 0.75 0 0 0.205 0.090 0.145 1 0 0 0 0.255 0.150 0.160 1 0 0 0" ctrl="0 0.45 -0.85 0.75 0 0.70"/>
  </keyframe>
</mujoco>
