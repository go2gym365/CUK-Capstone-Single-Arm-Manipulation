<mujoco model="dofbot">
  <compiler angle="radian" meshdir="meshes" autolimits="true"/>
  <option timestep="0.005" gravity="0 0 -9.81" integrator="RK4"/>
  <size njmax="3000" nconmax="800"/>

  <visual>
    <headlight ambient="0.5 0.5 0.5" diffuse="0.8 0.8 0.8" specular="0.15 0.15 0.15"/>
    <rgba haze="0.15 0.25 0.35 1"/>
  </visual>

  <statistic center="0 0 0.18" extent="0.50"/>

  <default>
    <default class="robot">
      <joint armature="0.01" damping="0.25" frictionloss="0.02"/>
      <geom type="mesh" density="700" condim="3" contype="1" conaffinity="1" group="1"/>
    </default>

    <default class="visual_only">
      <geom type="mesh" density="0" contype="0" conaffinity="0" group="2"/>
    </default>

    <default class="col">
      <geom type="capsule" rgba="0 0 0 0"
            friction="0.9 0.05 0.01"
            condim="4" solref="0.004 1" solimp="0.9 0.95 0.001"
            contype="1" conaffinity="1" group="3"/>
    </default>

    <default class="finger_col">
      <geom type="box"
            friction="1.2 0.05 0.01"
            condim="4" solref="0.003 1" solimp="0.9 0.95 0.001"
            contype="1" conaffinity="1" group="3"/>
    </default>
  </default>

  <asset>
    <material name="mat_gray"  rgba="0.25 0.25 0.25 1"/>
    <material name="mat_green" rgba="0.0 0.45 0.20 1"/>
    <material name="mat_white" rgba="0.75 0.75 0.75 1"/>
    <material name="mat_black" rgba="0.08 0.08 0.08 1"/>
    <material name="mat_goal"  rgba="1 0.2 0.2 0.9"/>
    <material name="mat_table" rgba="0.45 0.32 0.22 1"/>
    <material name="mat_cube"  rgba="0.85 0.25 0.20 1"/>

    <texture name="tex_floor_checker"
             type="2d"
             builtin="checker"
             rgb1="0.82 0.82 0.82"
             rgb2="0.62 0.62 0.62"
             width="512"
             height="512"/>

    <material name="mat_floor_checker"
              texture="tex_floor_checker"
              texrepeat="8 8"
              texuniform="true"
              reflectance="0.05"/>

    <mesh name="base_link_mesh" file="base_link.STL"/>
    <mesh name="link1_mesh" file="link1.STL"/>
    <mesh name="link2_mesh" file="link2.STL"/>
    <mesh name="link3_mesh" file="link3.STL"/>
    <mesh name="link4_mesh" file="link4.STL"/>
    <mesh name="link5_mesh" file="link5.STL"/>
  </asset>

  <worldbody>
    <light pos="0 0 1.5" dir="0 0 -1"/>
    <camera name="front_cam" pos="0 1.1 0.7" mode="targetbody" target="base_link"/>
    <geom name="floor" type="plane" size="2 2 0.1" material="mat_floor_checker"/>

    <body name="table" pos="0.00 0.18 0.10">
      <geom name="table_geom" type="box" size="0.32 0.18 0.02" material="mat_table"
            friction="1.0 0.05 0.01"/>
    </body>

    <body name="object_main" pos="0.10 0.15 0.136">
      <freejoint name="object_main_free"/>
      <inertial pos="0 0 0" mass="0.03" diaginertia="0.00001 0.00001 0.00001"/>
      <geom name="object_main_geom" type="box" size="0.015 0.015 0.015" material="mat_cube"
            friction="1.1 0.05 0.01"/>
      <site name="object_main_site" pos="0 0 0" size="0.007" rgba="1 1 0 1"/>
    </body>

    <body name="object_bottle" pos="0.10 0.05 0.150">
      <freejoint name="object_bottle_free"/>
      <inertial pos="0 0 -0.01" mass="0.03" diaginertia="0.00001 0.00001 0.00001"/>
      
      <geom name="object_bottle_geom" type="cylinder" size="0.015 0.030" rgba="0.7 0.85 0.95 0.5"
            friction="1.1 0.05 0.01"/>
            
      <geom name="object_bottle_neck" type="cylinder" size="0.010 0.010" pos="0 0 0.040"
            rgba="0.7 0.85 0.95 0.5" friction="1.1 0.05 0.01"/>
            
      <geom name="object_bottle_cap" type="cylinder" size="0.011 0.005" pos="0 0 0.055"
            rgba="0.1 0.4 0.9 1" friction="1.1 0.05 0.01"/>
            
      <site name="object_bottle_site" pos="0 0 0" size="0.007" rgba="1 1 0 1"/>
    </body>

    <body name="target_blue" pos="-0.15 0.15 0.124">
      <geom name="target_blue_geom" type="cylinder" size="0.032 0.004"
            rgba="0.2 0.45 1.0 0.9" contype="0" conaffinity="0"/>
      <site name="target_blue_site" pos="0 0 0.004" size="0.008" rgba="0.2 0.45 1 1"/>
    </body>

    <body name="target_purple" pos="-0.15 0.05 0.124">
      <geom name="target_purple_geom" type="cylinder" size="0.032 0.004"
            rgba="0.65 0.35 0.85 0.9" contype="0" conaffinity="0"/>
      <site name="target_purple_site" pos="0 0 0.004" size="0.008" rgba="0.65 0.35 0.85 1"/>
    </body>

    <body name="base_link" pos="0 0 0">
      <inertial pos="0 0 0.03" mass="0.45" diaginertia="0.001 0.001 0.001"/>
      <geom class="robot" name="base_link_geom" mesh="base_link_mesh" material="mat_gray"/>

      <geom class="col" name="base_link_col" type="cylinder"
            pos="0 0 0.035" size="0.0675 0.035"/>

      <body name="link1" pos="0 0 0.06605" euler="-0.010805 0 0">
        <joint name="joint1" type="hinge" axis="0 0 1" range="-1.5708 1.5708"/>
        <inertial pos="0 0 0.02" mass="0.12" diaginertia="0.0004 0.0004 0.0002"/>
        <geom class="robot" name="link1_geom" mesh="link1_mesh" material="mat_green"/>
        <geom class="col" name="link1_col" fromto="0 0 0.005 0 0 0.055" size="0.018"/>

        <body name="link2" pos="0 -0.00031873 0.04145" euler="0 1.5708 0">
          <joint name="joint2" type="hinge" axis="0 0 1" range="-1.5708 1.5708"/>
          <inertial pos="-0.04 0 0" mass="0.15" diaginertia="0.00035 0.00035 0.00012"/>
          <geom class="robot" name="link2_geom" mesh="link2_mesh" material="mat_gray"/>
          <geom class="col" name="link2_col" fromto="0 0 0 -0.08285 0 0" size="0.014"/>

          <body name="link3" pos="-0.08285 0 0">
            <joint name="joint3" type="hinge" axis="0 0 1" range="-1.5708 1.5708"/>
            <inertial pos="-0.04 0 0" mass="0.12" diaginertia="0.00030 0.00030 0.00010"/>
            <geom class="robot" name="link3_geom" mesh="link3_mesh" material="mat_green"/>
            <geom class="col" name="link3_col" fromto="0 0 0 -0.08285 0 0" size="0.013"/>

            <body name="link4" pos="-0.08285 0 0" euler="0 0 0.0083081">
              <joint name="joint4" type="hinge" axis="0 0 1" range="-1.5708 1.5708"/>
              <inertial pos="-0.0395 0 0" mass="0.10" diaginertia="0.00018 0.00018 0.00008"/>
              <geom class="robot" name="link4_geom" mesh="link4_mesh" material="mat_gray"/>
              <geom class="col" name="link4_col" fromto="0 0 0 -0.07905 0 0" size="0.012"/>

              <body name="link5" pos="-0.07905 -0.001 0" euler="0 -1.57 0">
                <joint name="joint5" type="hinge" axis="0 0 1" range="-1.5708 3.1416"/>
                <inertial pos="0 0 0.018" mass="0.08" diaginertia="0.00010 0.00010 0.00005"/>
                <geom class="robot" name="link5_geom" mesh="link5_mesh" material="mat_green"/>
                <geom class="col" name="link5_col" fromto="0 0 0 0 0 0.070" size="0.010"/>

                <site name="ee_site" pos="0 0 0.108" size="0.008" rgba="0 1 0 1"/>
                <site name="tool_site" pos="0 0 0.108" size="0.012" rgba="0 0.5 1 0.8"/>

                <body name="gripper_base" pos="0 0 0.082">
                  <inertial pos="0 0 0" mass="0.05" diaginertia="0.00003 0.00003 0.00003"/>

                  <geom name="gripper_palm" type="box" size="0.022 0.012 0.010"
                        material="mat_black" friction="1.0 0.05 0.01"/>

                  <site name="grasp_site" pos="0 0 0.034" size="0.006" rgba="1 0 0 1"/>

                  <body name="left_finger" pos="0 0.033 0.022">
                    <joint name="left_finger_joint" type="slide" axis="0 -1 0"
                           range="0 0.028" damping="0.5" armature="0.001"/>
                    <inertial pos="0 0 0.020" mass="0.015"
                              diaginertia="0.00001 0.00001 0.00001"/>
                    <geom class="finger_col" name="left_finger_geom"
                          pos="0 0 0.020" size="0.004 0.003 0.020"
                          material="mat_black"/>
                  </body>

                  <body name="right_finger" pos="0 -0.033 0.022">
                    <joint name="right_finger_joint" type="slide" axis="0 1 0"
                           range="0 0.028" damping="0.5" armature="0.001"/>
                    <inertial pos="0 0 0.020" mass="0.015"
                              diaginertia="0.00001 0.00001 0.00001"/>
                    <geom class="finger_col" name="right_finger_geom"
                          pos="0 0 0.020" size="0.004 0.003 0.020"
                          material="mat_black"/>
                  </body>
                </body>
              </body>
            </body>
          </body>
        </body>
      </body>
    </body>
  </worldbody>

  <equality>
    <joint joint1="left_finger_joint" joint2="right_finger_joint" polycoef="0 1 0 0 0"/>
  </equality>

  <contact>
    <exclude body1="base_link" body2="link1"/>
    <exclude body1="base_link" body2="link2"/>
    <exclude body1="base_link" body2="link3"/>
    <exclude body1="link1" body2="link2"/>
    <exclude body1="link1" body2="link3"/>
    <exclude body1="link1" body2="link4"/>
    <exclude body1="link1" body2="link5"/>
    <exclude body1="link2" body2="link3"/>
    <exclude body1="link2" body2="link4"/>
    <exclude body1="link2" body2="link5"/>
    <exclude body1="link3" body2="link4"/>
    <exclude body1="link3" body2="link5"/>
    <exclude body1="link4" body2="link5"/>

    <exclude body1="link5" body2="gripper_base"/>
    <exclude body1="gripper_base" body2="left_finger"/>
    <exclude body1="gripper_base" body2="right_finger"/>
    <exclude body1="left_finger" body2="right_finger"/>
  </contact>

  <actuator>
    <position name="a_joint1" joint="joint1" kp="45" kv="4.5"
              ctrlrange="-1.5708 1.5708" forcerange="-8 8"/>
    <position name="a_joint2" joint="joint2" kp="40" kv="4.0"
              ctrlrange="-1.5708 1.5708" forcerange="-8 8"/>
    <position name="a_joint3" joint="joint3" kp="35" kv="3.5"
              ctrlrange="-1.5708 1.5708" forcerange="-6 6"/>
    <position name="a_joint4" joint="joint4" kp="25" kv="2.5"
              ctrlrange="-1.5708 1.5708" forcerange="-5 5"/>
    <position name="a_joint5" joint="joint5" kp="20" kv="2.0"
              ctrlrange="-1.5708 3.1416" forcerange="-4 4"/>

    <position name="a_gripper" joint="left_finger_joint" kp="120" kv="8"
              ctrlrange="0 0.028" forcerange="-3 3"/>
  </actuator>

  <sensor>
    <jointpos name="joint1_pos" joint="joint1"/>
    <jointpos name="joint2_pos" joint="joint2"/>
    <jointpos name="joint3_pos" joint="joint3"/>
    <jointpos name="joint4_pos" joint="joint4"/>
    <jointpos name="joint5_pos" joint="joint5"/>
    <jointpos name="left_finger_pos" joint="left_finger_joint"/>

    <jointvel name="joint1_vel" joint="joint1"/>
    <jointvel name="joint2_vel" joint="joint2"/>
    <jointvel name="joint3_vel" joint="joint3"/>
    <jointvel name="joint4_vel" joint="joint4"/>
    <jointvel name="joint5_vel" joint="joint5"/>
    <jointvel name="left_finger_vel" joint="left_finger_joint"/>

    <framepos name="ee_pos" objtype="site" objname="ee_site"/>
    <framepos name="grasp_pos" objtype="site" objname="grasp_site"/>
    <framepos name="object_main_pos" objtype="site" objname="object_main_site"/>
    <framepos name="object_bottle_pos" objtype="site" objname="object_bottle_site"/>
    <framepos name="target_blue_pos" objtype="site" objname="target_blue_site"/>
    <framepos name="target_purple_pos" objtype="site" objname="target_purple_site"/>
  </sensor>
</mujoco>