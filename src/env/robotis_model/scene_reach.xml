<mujoco model="omx reach scene">
  <include file="omx.xml"/>

  <statistic center="0.2 0 0.2" extent="0.9"/>

  <visual>
    <headlight diffuse="0.6 0.6 0.6" ambient="0.3 0.3 0.3" specular="0 0 0"/>
    <rgba haze="0.15 0.25 0.35 1"/>
    <global azimuth="120" elevation="-20"/>
  </visual>

  <asset>
    <texture
      type="skybox"
      builtin="gradient"
      rgb1="0.3 0.5 0.7"
      rgb2="0 0 0"
      width="512"
      height="3072"
    />
    <texture
      type="2d"
      name="groundplane"
      builtin="checker"
      mark="edge"
      rgb1="0.2 0.3 0.4"
      rgb2="0.1 0.2 0.3"
      markrgb="0.8 0.8 0.8"
      width="300"
      height="300"
    />
    <material
      name="groundplane"
      texture="groundplane"
      texuniform="true"
      texrepeat="5 5"
      reflectance="0.2"
    />
    <material name="table_mat" rgba="0.23 0.23 0.25 1"/>
    <material name="cube_mat" rgba="0.1 0.55 0.95 1"/>
  </asset>

  <worldbody>
    <light pos="0 0 1.4" dir="0 0 -1" directional="true"/>
    <geom name="floor" size="0 0 0.05" type="plane" material="groundplane"/>

    <body name="table" pos="0.22 0 0.02">
      <geom name="table_geom" type="box" size="0.18 0.18 0.015" material="table_mat"/>
    </body>

    <body name="object_main" pos="0.24 0.0 0.047">
      <freejoint name="object_main_free"/>
      <geom
        name="object_main_geom"
        type="box"
        size="0.012 0.012 0.012"
        density="900"
        friction="0.9 0.08 0.03"
        material="cube_mat"
      />
      <site name="object_main_site" pos="0 0 0" size="0.005" rgba="1 0.1 0.1 1"/>
    </body>

    <site name="reach_target_site" pos="0.24 0.0 0.10" size="0.007" rgba="1 1 0.1 1"/>
  </worldbody>
</mujoco>
